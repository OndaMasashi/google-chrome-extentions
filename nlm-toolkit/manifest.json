{
  "manifest_version": 3,
  "name": "NotebookLM Toolkit",
  "version": "2.0.0",
  "description": "NotebookLMのノートブック一覧に作成日順ソート・タイトル検索機能を追加します",
  "content_scripts": [
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
